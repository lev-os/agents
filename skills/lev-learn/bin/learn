#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
Usage: learn [context]

Runs a guided interview, writes a proposal artifact, and emits a handoff
command back to the work lifecycle.
EOF
}

infer_context() {
  local git_root branch inferred

  if git_root="$(git rev-parse --show-toplevel 2>/dev/null)"; then
    inferred="$(basename "$git_root")"
    branch="$(git rev-parse --abbrev-ref HEAD 2>/dev/null || true)"
    if [[ -n "${branch}" && "${branch}" != "HEAD" ]]; then
      inferred="${inferred} (${branch})"
    fi
    printf '%s' "${inferred}"
    return 0
  fi

  printf '%s' "$(basename "$PWD")"
}

slugify() {
  printf '%s' "$1" \
    | tr '[:upper:]' '[:lower:]' \
    | sed -E 's/[^a-z0-9]+/-/g; s/^-+//; s/-+$//; s/-{2,}/-/g'
}

escape_yaml() {
  printf '%s' "$1" | sed 's/"/\\"/g'
}

ask() {
  local prompt="$1"
  local default="${2:-}"
  local response=""

  if [[ -n "${default}" ]]; then
    printf '%s [%s]: ' "${prompt}" "${default}"
  else
    printf '%s: ' "${prompt}"
  fi

  read -r response || true
  if [[ -z "${response}" ]]; then
    response="${default}"
  fi

  printf '%s' "${response}"
}

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  usage
  exit 0
fi

if [[ ! -t 0 ]]; then
  echo "learn requires an interactive terminal for question-by-question input." >&2
  exit 1
fi

context="${*:-}"
if [[ -z "${context}" ]]; then
  context="$(infer_context)"
fi

echo "lev-learn interview"
echo "Answer one question at a time. Press Enter to accept defaults."
echo

context="$(ask "Context" "${context}")"
outcome="$(ask "1/8 Outcome to achieve")"
problem="$(ask "2/8 Problem or opportunity")"
stakeholders="$(ask "3/8 Users/stakeholders impacted")"
constraints="$(ask "4/8 Constraints or non-goals")"
evidence="$(ask "5/8 Prior art or evidence to reuse")"
approach="$(ask "6/8 Proposed approach direction")"
success="$(ask "7/8 Success criteria")"
first_slice="$(ask "8/8 Smallest first slice to ship")"

if [[ -z "${context}" ]]; then
  context="workspace"
fi
if [[ -z "${outcome}" ]]; then
  outcome="Define a concrete outcome for ${context}."
fi
if [[ -z "${problem}" ]]; then
  problem="Clarify the current gap and why it matters now."
fi
if [[ -z "${stakeholders}" ]]; then
  stakeholders="Primary owner + directly affected users."
fi
if [[ -z "${constraints}" ]]; then
  constraints="No explicit constraints provided yet."
fi
if [[ -z "${evidence}" ]]; then
  evidence="No prior art captured yet; run work prior-art checks before implementation."
fi
if [[ -z "${approach}" ]]; then
  approach="Refine approach during crystallized spec authoring."
fi
if [[ -z "${success}" ]]; then
  success="Define measurable acceptance criteria in the spec."
fi
if [[ -z "${first_slice}" ]]; then
  first_slice="Implement the smallest vertical slice that proves feasibility."
fi

proposal_dir="${LEV_PM_PROPOSALS:-.lev/pm/proposals}"
mkdir -p "${proposal_dir}"

slug="$(slugify "${context}")"
if [[ -z "${slug}" ]]; then
  slug="learn-context"
fi

date_ymd="$(date +%Y-%m-%d)"
date_stamp="$(date +%Y-%m-%d-%H%M%S)"
date_iso="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
proposal_path="${proposal_dir}/proposal-${slug}-${date_ymd}.md"
if [[ -e "${proposal_path}" ]]; then
  proposal_path="${proposal_dir}/proposal-${slug}-${date_stamp}.md"
fi

escaped_context="$(escape_yaml "${context}")"
escaped_path="$(escape_yaml "${proposal_path}")"

cat > "${proposal_path}" <<EOF
---
type: proposal
generated_by: lev-learn
generated_at: ${date_iso}
context: "${escaped_context}"
handoff_to: work
next_stage: crystallized
---

# Proposal: ${context}

## Desired Outcome
${outcome}

## Problem / Opportunity
${problem}

## Stakeholders
${stakeholders}

## Constraints / Non-Goals
${constraints}

## Prior Art / Evidence
${evidence}

## Proposed Approach
${approach}

## Success Criteria
${success}

## First Slice
${first_slice}

## Lifecycle Handoff
- Current stage: \`crystallizing\` (guided learn mode)
- Next stage: \`crystallized\`
- Route: \`work\`
- Next command: \`work --stage=crystallized "Create spec from ${escaped_path}"\`
EOF

echo
echo "Proposal created: ${proposal_path}"
echo "Handoff command:"
echo "work --stage=crystallized \"Create spec from ${proposal_path}\""

if command -v work >/dev/null 2>&1; then
  run_now="$(ask "Run handoff command now? (y/N)" "N")"
  case "${run_now}" in
    y|Y|yes|YES)
      work --stage=crystallized "Create spec from ${proposal_path}"
      ;;
  esac
fi
