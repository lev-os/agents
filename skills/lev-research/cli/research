#!/usr/bin/env bash
# research - Deep Research Intelligence System CLI v0.9
# XDG-compliant session management

set -e

VERSION="0.9.0"
XDG_DATA="${HOME}/.config/LEV/research"
SESSIONS_DIR="${XDG_DATA}/sessions"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m'

# Generate session ID
generate_session_id() {
    local query="$1"
    local timestamp=$(date +%Y%m%d-%H%M)
    local slug=$(echo "$query" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9]/-/g' | sed 's/--*/-/g' | cut -c1-40)
    echo "${timestamp}_${slug}"
}

# Initialize new session
cmd_init() {
    local query="$1"
    if [[ -z "$query" ]]; then
        echo -e "${RED}Error: Query required${NC}"
        echo "Usage: research init \"<query>\""
        exit 1
    fi

    local session_id=$(generate_session_id "$query")
    local date_dir=$(date +%Y-%m-%d)
    local session_dir="${SESSIONS_DIR}/${date_dir}/${session_id}"

    mkdir -p "${session_dir}/artifacts"

    cat > "${session_dir}/session.json" << EOF
{
  "id": "${session_id}",
  "query": "${query}",
  "status": "open",
  "created_at": "$(date -u +%Y-%m-%dT%H:%M:%SZ)",
  "updated_at": "$(date -u +%Y-%m-%dT%H:%M:%SZ)",
  "confidence": 0,
  "turns": 0,
  "sources_count": 0
}
EOF

    echo '{"timestamp":"'$(date -u +%Y-%m-%dT%H:%M:%SZ)'","query":"'"$query"'","type":"initial"}' > "${session_dir}/queries.jsonl"
    touch "${session_dir}/sources.jsonl"

    echo -e "${GREEN}✓ Session initialized: ${session_id}${NC}"
    echo -e "${CYAN}  Directory: ${session_dir}${NC}"
}

# List sessions
cmd_list() {
    local status_filter="${1:-all}"
    echo -e "${CYAN}Research Sessions${NC}"
    echo "─────────────────────────────────────────────────"
    
    if [[ ! -d "$SESSIONS_DIR" ]]; then
        echo "No sessions found."
        return
    fi

    find "$SESSIONS_DIR" -name "session.json" -type f 2>/dev/null | while read session_file; do
        local id=$(jq -r '.id' "$session_file" 2>/dev/null)
        local query=$(jq -r '.query' "$session_file" 2>/dev/null | cut -c1-50)
        local status=$(jq -r '.status' "$session_file" 2>/dev/null)
        
        if [[ "$status_filter" != "all" && "$status" != "$status_filter" ]]; then
            continue
        fi

        local status_icon="⏳"
        [[ "$status" == "completed" ]] && status_icon="✓"

        echo -e "${status_icon} ${BLUE}${id}${NC} - ${query}..."
    done
}

# Show session
cmd_show() {
    local session_id="$1"
    local session_file=$(find "$SESSIONS_DIR" -path "*${session_id}*/session.json" -type f 2>/dev/null | head -1)
    if [[ -z "$session_file" ]]; then
        echo -e "${RED}Session not found: ${session_id}${NC}"
        exit 1
    fi
    jq '.' "$session_file"
}

# Validate session
cmd_validate() {
    local session_id="$1"
    local session_file=$(find "$SESSIONS_DIR" -path "*${session_id}*/session.json" -type f 2>/dev/null | head -1)
    if [[ -z "$session_file" ]]; then
        echo -e "${RED}Session not found${NC}"
        exit 1
    fi

    local dir=$(dirname "$session_file")
    echo -e "${CYAN}Validating: ${session_id}${NC}"
    
    [[ -f "${dir}/session.json" ]] && echo -e "  session.json: ${GREEN}✓${NC}" || echo -e "  session.json: ${RED}✗${NC}"
    [[ -f "${dir}/sources.jsonl" ]] && echo -e "  sources.jsonl: ${GREEN}✓${NC}" || echo -e "  sources.jsonl: ${RED}✗${NC}"
    
    local count=$(wc -l < "${dir}/sources.jsonl" 2>/dev/null | tr -d ' ')
    echo -e "  Sources: ${count:-0}"
}

# Complete session
cmd_complete() {
    local session_id="$1"
    local session_file=$(find "$SESSIONS_DIR" -path "*${session_id}*/session.json" -type f 2>/dev/null | head -1)
    if [[ -z "$session_file" ]]; then
        echo -e "${RED}Session not found${NC}"
        exit 1
    fi

    local tmp=$(mktemp)
    jq '.status = "completed" | .updated_at = "'$(date -u +%Y-%m-%dT%H:%M:%SZ)'"' "$session_file" > "$tmp"
    mv "$tmp" "$session_file"
    echo -e "${GREEN}✓ Session completed${NC}"
}

# Help
cmd_help() {
    echo -e "${CYAN}research${NC} - Deep Research CLI v${VERSION}"
    echo ""
    echo "Commands:"
    echo "  init <query>    Initialize new session"
    echo "  list [status]   List sessions (all/open/completed)"
    echo "  show <id>       Show session details"
    echo "  validate <id>   Validate session"
    echo "  complete <id>   Mark complete"
    echo ""
    echo "Storage: ~/.config/LEV/research/"
}

case "${1:-help}" in
    init)       cmd_init "$2" ;;
    list)       cmd_list "$2" ;;
    show)       cmd_show "$2" ;;
    validate)   cmd_validate "$2" ;;
    complete)   cmd_complete "$2" ;;
    help|--help|-h)  cmd_help ;;
    *)          echo -e "${RED}Unknown: $1${NC}"; cmd_help ;;
esac
