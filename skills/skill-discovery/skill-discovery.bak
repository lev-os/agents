#!/usr/bin/env python3
"""Local skill discovery over qmd collections."""

from __future__ import annotations

import json
import os
import re
import shutil
import subprocess
import sys
from pathlib import Path


ROOT = Path(os.environ.get("SKILLS_ROOT", str(Path.home() / ".agents"))).resolve()
JSON_MODE = False
TASK = ""
USE_CM = os.environ.get("SKILL_DISCOVERY_USE_CM", "0") == "1"
ALL_COLLECTIONS = os.environ.get("SKILL_DISCOVERY_ALL", "1") == "1"
CATEGORY_FILTER = [
    item.strip().lower()
    for item in os.environ.get("SKILL_DISCOVERY_CATEGORY", "").split(",")
    if item.strip()
]

HARD_HIDDEN_CATEGORIES = {".archive", "_todo", "_workshop"}
LOW_COVERAGE_TERMS = {"legal", "screenplay", "script", "video", "directing", "storyboarding"}
PROBLEM_TERMS = {"problem solving", "root cause", "systems thinking", "decision making", "debugging"}
PERSONA_TERMS = {"persona", "empathy", "user research", "synthetic user", "worldview", "simulation", "axiom", "tribal"}
SDK_TERMS = {"sdk", "client", "api", "tooling", "package", "library", "cli"}
SKILL_DOC_RE = re.compile(r"/skill(?:[.-][^/]+)?\.md$", re.I)
README_RE = re.compile(r"/(?:readme|index)\.md$", re.I)

CATEGORY_ALIASES = {
    "engineering": {"dev", "devops", "sdk", "testing", "security", "tools", "workflow", "ai-agents"},
    "live-dev": {"dev", "devops", "testing", "workflow"},
    "design": {"design-ux", "thinking"},
    "branding": {"marketing", "design-ux"},
    "content": {"marketing"},
    "seo": {"marketing"},
    "geo": {"geo", "marketing"},
    "problem-solving": {"thinking"},
    "social": {"marketing"},
}

BOOST_RULES = [
    {
        "terms": {"live dev", "engineering", "software engineering", "implementation"},
        "categories": {"dev", "devops", "testing", "workflow"},
        "names": {"clean-code", "code-review", "grim-repo-auditor", "lev-cdo", "tdd-workflow"},
    },
    {
        "terms": {"design", "ux", "ui", "wireframe", "wireframes", "components"},
        "categories": {"design-ux", "thinking"},
        "names": {"ux", "lev-design", "design-os", "visual-explainer"},
    },
    {
        "terms": {"branding", "positioning", "messaging", "identity", "voice"},
        "categories": {"marketing"},
        "names": {"marketing-psychology", "product-marketing-context", "copywriting", "content-strategy"},
    },
    {
        "terms": {"seo", "schema", "metadata", "ranking"},
        "categories": {"marketing"},
        "names": {"seo-audit", "schema-markup", "programmatic-seo"},
    },
    {
        "terms": {"geo", "llms txt", "ai visibility", "citations"},
        "categories": {"geo"},
        "names": {"geo", "geo-audit", "geo-schema", "geo-technical", "geo-citability", "geo-llmstxt"},
    },
    {
        "terms": {"marketing", "campaign", "funnel"},
        "categories": {"marketing"},
        "names": {"marketing-psychology", "copywriting", "content-strategy", "social-content"},
    },
    {
        "terms": {"content generation", "editorial", "copywriting", "blog"},
        "categories": {"marketing"},
        "names": {"content-strategy", "copywriting", "copy-editing", "blog-writer", "social-content"},
    },
    {
        "terms": PROBLEM_TERMS,
        "categories": {"thinking"},
        "names": {"lev-cdo", "lev-cdo-debug", "sidequest"},
    },
    {
        "terms": PERSONA_TERMS,
        "categories": {"thinking"},
        "names": {"map-elements", "dig-axioms", "multi-devils-debate", "emotional-tribal-mapper", "axiom-drill-down"},
    },
]


def usage() -> int:
    print(
        "\n".join(
            [
                "skill-discovery — find relevant local skills for a task",
                "",
                "USAGE",
                '  skill-discovery "task description"',
                '  skill-discovery "task description" --json',
                "  skill-discovery --help",
                "",
                "BEHAVIOR",
                '  - Searches qmd collections whose names start with "skills"',
                "  - Prefers canonical and skills-db hits in post-processing",
                "  - Hides maintenance buckets (.archive, _todo, _workshop) from normal results",
                "  - Recommends external find-skills only when local discovery quality is low",
            ]
        )
    )
    return 0


def parse_args() -> None:
    global JSON_MODE, TASK
    for arg in sys.argv[1:]:
        if arg in {"--help", "-h"}:
            raise SystemExit(usage())
        if arg == "--json":
            JSON_MODE = True
        else:
            TASK = arg
    if not TASK:
        raise SystemExit("error: task description required")


def run_command(cmd: list[str], *, timeout: float = 15.0) -> subprocess.CompletedProcess[str]:
    return subprocess.run(cmd, capture_output=True, text=True, timeout=timeout, check=False)


def discover_qmd_collections() -> list[str]:
    result = run_command(["qmd", "collection", "list"], timeout=5.0)
    names: list[str] = []
    for line in result.stdout.splitlines():
        match = re.match(r"^(\S+)\s+\(qmd://", line)
        if not match:
            continue
        name = match.group(1)
        if not name.startswith("skills"):
            continue
        if not ALL_COLLECTIONS and name not in {"skills-canonical", "skills-db"}:
            continue
        names.append(name)
    if not names:
        return ["skills-canonical", "skills-db"]
    return names


def collection_roots(collections: list[str]) -> dict[str, str]:
    roots: dict[str, str] = {}
    for name in collections:
        result = run_command(["qmd", "collection", "show", name], timeout=5.0)
        match = re.search(r"^\s*Path:\s+(\S+)", result.stdout, re.M)
        if match:
            roots[name] = match.group(1)
    return roots


def run_cm() -> list[str]:
    if not USE_CM or shutil.which("cm") is None:
        return []
    result = run_command(["cm", "context", TASK, "--json"], timeout=10.0)
    if result.returncode != 0:
        return []
    try:
        payload = json.loads(result.stdout)
    except json.JSONDecodeError:
        return []
    bullets: list[str] = []
    for key in ("rules", "matches", "bullets", "relevantBullets"):
        value = payload.get(key) or []
        bullets.extend(str(item) for item in value)
    return bullets


def parse_qmd_lines(raw: str) -> list[dict]:
    matches = []
    for line in raw.splitlines():
        if not line.startswith("#"):
            continue
        parts = line.split(",")
        if len(parts) < 3:
            continue
        matches.append(
            {
                "path": ",".join(parts[2:]),
                "score": float(parts[1] or 0.0),
                "collection": re.match(r"^qmd://([^/]+)", ",".join(parts[2:])).group(1),
            }
        )
    return matches


def run_qmd(collections: list[str]) -> list[dict]:
    primary = [name for name in collections if name in {"skills-canonical", "skills-db"}]
    secondary = [name for name in collections if name not in {"skills-canonical", "skills-db"}]
    if not primary:
        primary = list(collections)

    merged: list[dict] = []
    for name in primary:
        result = run_command(["qmd", "search", TASK, "-c", name, "--files", "-n", "8"], timeout=5.0)
        if result.returncode == 0:
            merged.extend(parse_qmd_lines(result.stdout))

    if ALL_COLLECTIONS:
        for name in secondary:
            result = run_command(["qmd", "search", TASK, "-c", name, "--files", "-n", "5"], timeout=5.0)
            if result.returncode == 0:
                merged.extend(parse_qmd_lines(result.stdout))

    if len(merged) < 6:
        query_cmd = ["qmd", "query", TASK, "--files", "-n", "14", "-C", "18"]
        for name in collections:
            query_cmd.extend(["-c", name])
        result = run_command(query_cmd, timeout=12.0)
        if result.returncode == 0:
            merged.extend(parse_qmd_lines(result.stdout))

    merged.sort(key=lambda item: item["score"], reverse=True)
    return merged[:30]


def resolve_local_path(uri: str, roots: dict[str, str]) -> str:
    if not uri.startswith("qmd://"):
        return uri
    rest = uri[len("qmd://") :]
    collection, _, rel = rest.partition("/")
    root = roots.get(collection)
    if not root:
        return uri
    root_path = Path(root)
    rel_path = Path(rel)
    candidates = [root_path / rel_path]
    rel_str = rel_path.as_posix()
    if rel_str.endswith("/skill.md"):
        candidates.append(root_path / rel_str[: -len("/skill.md")] / "SKILL.md")
    if rel_str.endswith("/readme.md"):
        candidates.append(root_path / rel_str[: -len("/readme.md")] / "README.md")
    if "/skill-v" in rel_str and rel_str.endswith(".md"):
        skill_dir = root_path / rel_path.parent
        if skill_dir.exists():
            candidates.extend(sorted(skill_dir.glob("SKILL*.md")))
    parent = root_path / rel_path.parent
    basename = rel_path.name.lower()
    if parent.exists():
        for child in parent.iterdir():
            if child.name.lower() == basename:
                candidates.append(child)
    for candidate in candidates:
        if candidate.exists():
            return str(candidate.resolve())
    return str(root_path / rel_path)


def contains_any(terms: set[str], text: str) -> bool:
    return any(term in text for term in terms)


def enrich(matches: list[dict], roots: dict[str, str]) -> list[dict]:
    query_text = TASK.lower()
    enriched = []
    for match in matches:
        uri = match["path"]
        score = float(match["score"])
        collection = match["collection"]
        parts = uri[len("qmd://") :].split("/") if uri.startswith("qmd://") else []
        rel_parts = parts[1:] if len(parts) > 1 else []
        skill_name = rel_parts[-2] if len(rel_parts) >= 2 else ""

        if collection == "skills-db" and len(rel_parts) >= 3:
            category = rel_parts[0]
        elif collection == "skills-canonical":
            category = "skills"
        else:
            category = collection

        if SKILL_DOC_RE.search(uri):
            doc_type = "skill"
        elif README_RE.search(uri):
            doc_type = "summary"
        elif any(token in uri for token in ("/references/", "/assets/", "/examples/", "/templates/", "/work/", "/notes/", "/logs/")):
            doc_type = "reference"
        else:
            doc_type = "other"

        adjusted = score
        if collection == "skills-canonical":
            adjusted += 0.35
        elif collection == "skills-db":
            adjusted += 0.22
        elif collection.startswith("skills-"):
            adjusted += 0.05

        if doc_type == "skill":
            adjusted += 0.25
        elif doc_type == "summary":
            adjusted -= 0.08
        else:
            adjusted -= 0.25

        local_path = resolve_local_path(uri, roots)
        path_lower = local_path.lower()

        if category in HARD_HIDDEN_CATEGORIES:
            adjusted -= 4.0
        if category == "thinking" and "/work/" in path_lower:
            adjusted -= 0.45
        if category == "thinking" and not contains_any(PROBLEM_TERMS | PERSONA_TERMS | {"design", "ux", "ui"}, query_text):
            adjusted -= 0.12
        if category == "sdk" and not contains_any(SDK_TERMS, query_text):
            adjusted -= 0.25
        if collection not in {"skills-canonical", "skills-db"}:
            adjusted -= 0.05

        for rule in BOOST_RULES:
            if contains_any(set(rule["terms"]), query_text):
                if category in rule["categories"]:
                    adjusted += 0.18
                if skill_name in rule["names"]:
                    adjusted += 0.22
                if any(name in path_lower for name in rule["names"]):
                    adjusted += 0.08

        if "geo" in query_text and skill_name.startswith("geo"):
            adjusted += 0.35
        if "seo" in query_text and skill_name in {"seo-audit", "schema-markup", "programmatic-seo"}:
            adjusted += 0.18

        enriched.append(
            {
                **match,
                "doc_type": doc_type,
                "skill_name": skill_name,
                "category": category,
                "local_path": local_path,
                "adjusted_score": round(adjusted, 4),
            }
        )

    enriched = [item for item in enriched if item["category"] not in HARD_HIDDEN_CATEGORIES]
    if CATEGORY_FILTER:
        expanded = set(CATEGORY_FILTER)
        for name in CATEGORY_FILTER:
            expanded.update(CATEGORY_ALIASES.get(name, set()))
        enriched = [
            item
            for item in enriched
            if item["category"].lower() in expanded
            or any(token in item["local_path"].lower() for token in CATEGORY_FILTER)
        ]

    enriched.sort(key=lambda item: item["adjusted_score"], reverse=True)
    return enriched


def quality_report(enriched: list[dict]) -> tuple[list[str], dict, bool]:
    query_text = TASK.lower()
    seen = set()
    skill_paths: list[str] = []
    primary_skill_hits: list[dict] = []
    for item in enriched:
        if item["doc_type"] != "skill":
            continue
        if item["local_path"] in seen:
            continue
        seen.add(item["local_path"])
        skill_paths.append(item["local_path"])
        if item["collection"] in {"skills-canonical", "skills-db"}:
            primary_skill_hits.append(item)

    quality_reasons: list[str] = []
    top_primary = primary_skill_hits[0]["adjusted_score"] if primary_skill_hits else 0.0
    if len(primary_skill_hits) >= 5 and top_primary >= 0.8:
        quality = "high"
    elif len(primary_skill_hits) >= 3 and top_primary >= 0.55:
        quality = "medium"
    else:
        quality = "low"

    if not primary_skill_hits:
        quality_reasons.append("no primary local skill docs found")
    if len(skill_paths) < 3:
        quality_reasons.append("fewer than 3 skill docs ranked")
    if any(item["collection"] not in {"skills-canonical", "skills-db"} for item in enriched[:3]):
        quality_reasons.append("secondary collections dominate top results")
    if any(term in query_text for term in LOW_COVERAGE_TERMS):
        top_names = {item["skill_name"] for item in primary_skill_hits[:3]}
        if not ({"copywriting", "copy-editing", "social-content"} & top_names):
            quality = "low"
            quality_reasons.append("domain coverage gap")
    if "legal" in query_text:
        quality = "low"
        quality_reasons.append("legal catalog coverage is not established")

    report = {
        "verdict": quality,
        "top_primary_score": round(top_primary, 4),
        "primary_skill_hits": len(primary_skill_hits),
        "reasons": quality_reasons,
    }
    return skill_paths[:10], report, quality == "low"


def main() -> int:
    parse_args()

    if shutil.which("qmd") is None:
        print("error: qmd is required but not found in PATH", file=sys.stderr)
        return 1

    collections = discover_qmd_collections()
    roots = collection_roots(collections)
    cm_bullets = run_cm()
    matches = run_qmd(collections)
    enriched = enrich(matches, roots)
    skill_paths, quality, recommend_find_skills = quality_report(enriched)

    output = {
        "query": TASK,
        "category_filter": CATEGORY_FILTER,
        "cm_bullets": cm_bullets,
        "qmd_collections": collections,
        "qmd_matches": enriched[:10],
        "skill_paths": skill_paths,
        "quality": quality,
        "recommend_find_skills": recommend_find_skills,
    }

    if JSON_MODE:
        print(json.dumps(output, indent=2))
        return 0

    print("=== Skill Discovery ===")
    print(f"Query: {TASK}")
    print()
    print(f"QMD collections: {', '.join(collections)}")
    print(f"Quality: {quality['verdict']}")
    print()
    print("Top skill paths:")
    for path in skill_paths:
        print(f"  - {path}")
    if recommend_find_skills:
        print()
        print("Recommendation: local results are low quality; consider find-skills as a fallback.")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
