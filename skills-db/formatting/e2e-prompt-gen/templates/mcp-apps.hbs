<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <style>
{{{cyberpunk_css}}}
  </style>
</head>
<body class="lev-theme-cyberpunk">
  <div id="app" class="lev-container">
    {{#each widgets}}
    {{{render this}}}
    {{/each}}
  </div>
  <script>
    // MCP Apps JSON-RPC over postMessage (SEP-1865)
    const pendingRequests = new Map();
    let requestId = 0;

    window.addEventListener('message', (e) => {
      const msg = e.data;
      if (msg.jsonrpc !== '2.0') return;

      if (msg.method) {
        // Incoming request/notification
        handleRequest(msg);
      } else if (msg.id !== undefined) {
        // Response to our request
        const handler = pendingRequests.get(msg.id);
        if (handler) {
          pendingRequests.delete(msg.id);
          if (msg.error) handler.reject(msg.error);
          else handler.resolve(msg.result);
        }
      }
    });

    function handleRequest(msg) {
      switch (msg.method) {
        case 'tools/result':
          renderToolResult(msg.params);
          break;
        case 'ui/update':
          updateUI(msg.params);
          break;
      }
    }

    function sendRequest(method, params) {
      const id = ++requestId;
      return new Promise((resolve, reject) => {
        pendingRequests.set(id, { resolve, reject });
        window.parent.postMessage({
          jsonrpc: '2.0',
          id,
          method,
          params
        }, '*');
      });
    }

    function renderToolResult(data) {
      document.getElementById('app').innerHTML = renderWidgets(data);
    }
  </script>
</body>
</html>
