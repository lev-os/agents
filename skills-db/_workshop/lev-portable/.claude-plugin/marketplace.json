{
  "name": "lev-portable",
  "version": "1.0.0",
  "description": "Portable architectural thinking toolkit — spec guard, shearing layers classifier, multi-perspective deliberation, cross-IDE skill search, and lightweight lifecycle router. No framework dependencies.",
  "author": "lev-os",
  "license": "MIT",
  "entry": "SKILL.md",
  "triggers": [
    "guard",
    "layers",
    "think",
    "find portable",
    "work portable",
    "spec check",
    "classify",
    "perspectives",
    "lev-portable"
  ],
  "tags": [
    "architecture",
    "thinking",
    "workflow",
    "portable",
    "cross-ide",
    "spec-guard",
    "shearing-layers",
    "deliberation"
  ],
  "references": [
    "references/guard.md",
    "references/layers.md",
    "references/think.md",
    "references/find.md",
    "references/work.md"
  ],
  "compatibility": {
    "claude-code": true,
    "cursor": true,
    "windsurf": true,
    "continue-dev": true,
    "cline": true,
    "roo-code": true
  },
  "install": {
    "command": "npx skills add lev-os/lev-portable",
    "paths": {
      "claude-code": "~/.claude/commands/lev-portable/",
      "cursor": "~/.cursor/skills/lev-portable/",
      "generic": "~/.agents/skills/lev-portable/"
    }
  }
}
