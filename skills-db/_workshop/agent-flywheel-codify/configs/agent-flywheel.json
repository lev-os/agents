{
  "name": "agent-flywheel",
  "description": "Bootstrap reproducible multi-agent coding environments with Claude, Codex, Gemini, modern CLI tools, onboarding, and safe resume-friendly setup patterns.",
  "base_url": "https://agent-flywheel.com/",
  "selectors": {
    "main_content": "main",
    "title": "h1",
    "code_blocks": "pre code"
  },
  "url_patterns": {
    "include": [
      "/",
      "/complete-guide",
      "/core-flywheel",
      "/flywheel",
      "/learn"
    ],
    "exclude": [
      "/wizard",
      "/pricing",
      "/_next",
      "/twitter-image",
      "/opengraph-image"
    ]
  },
  "checkpoint": {
    "enabled": true,
    "interval": 20
  },
  "rate_limit": 0.5,
  "max_pages": 86
}
