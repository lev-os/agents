  "elements": {
    "hero": {
      "type": "hero",
      "variant": "editorial",
      "props": {
        "category": "CONSOLIDATED TAXONOMY \u00b7 GRAPH-DRIVEN",
        "title": "Lifecycle Skill Venn",
        "subtitle": "Where OMX, OMC, OMO, Ouroboros, Hermes, OpenClaw, and Lev converge \u2014 and where they don't.",
        "meta": "2026-04-11 \u00b7 Source: ~/.agents/skill-graph.json (155 nodes, 112 edges)"
      },
      "children": [
        "hero-lead"
      ]
    },
    "hero-lead": {
      "type": "text",
      "variant": "lead",
      "props": {
        "content": "The 4-lane operator model (Shape \u2192 Plan \u2192 Deliver \u2192 Close) is the unification layer. Every competitor pattern maps to one of these lanes or a cross-lane concern. This page reads directly from the skill graph DB at ~/.agents/skill-graph.json and renders the Venn diagram. The graph is the source of truth; this is a projection."
      }
    },
    "kpis": {
      "type": "section",
      "variant": "kpi-row",
      "props": {
        "label": "INVENTORY",
        "title": "Graph State"
      },
      "children": [
        "kpi-nodes",
        "kpi-projects",
        "kpi-lanes",
        "kpi-edges"
      ]
    },
    "kpi-nodes": {
      "type": "card",
      "variant": "kpi",
      "props": {
        "value": 155,
        "label": "Graph Nodes"
      }
    },
    "kpi-projects": {
      "type": "card",
      "variant": "kpi",
      "props": {
        "value": 7,
        "label": "Source Projects"
      }
    },
    "kpi-lanes": {
      "type": "card",
      "variant": "kpi",
      "props": {
        "value": 4,
        "label": "Operator Lanes"
      }
    },
    "kpi-edges": {
      "type": "card",
      "variant": "kpi",
      "props": {
        "value": 112,
        "label": "Edges"
      }
    },
    "lanes-overview": {
      "type": "section",
      "variant": "card-grid",
      "props": {
        "label": "THE 4 LANES",
        "title": "Operator Model",
        "subtitle": "Hide raw role complexity. Show the lane. Expand internally."
      },
      "children": [
        "lane-shape",
        "lane-plan",
        "lane-deliver",
        "lane-close"
      ]
    },
    "lane-shape": {
      "type": "card",
      "variant": "elevated",
      "props": {
        "title": "\ud83e\udded SHAPE",
        "content": "**Alignment.** Requirements discovery, architecture interviewing, decomposing uncertainty.\n\nOperator question: *What exactly are we doing?*\n\nMaps to: arch-interview, work-deepen, deep-interview"
      }
    },
    "lane-plan": {
      "type": "card",
      "variant": "elevated",
      "props": {
        "title": "\ud83d\udcdd PLAN",
        "content": "**Crystallization.** Execution-ready plans, canon alignment, gate resolution, graph proposals.\n\nOperator question: *What is the approved route?*\n\nMaps to: sdlc-deepen-plan, plan-align-gates, ralplan"
      }
    },
    "lane-deliver": {
      "type": "card",
      "variant": "elevated",
      "props": {
        "title": "\u2699\ufe0f DELIVER",
        "content": "**Execution.** Coding, debugging, subagent coordination, retries, proofs.\n\nOperator question: *Can we ship this slice?*\n\nMaps to: sdlc-exec-validate, ralph, lev-ralph, team"
      }
    },
    "lane-close": {
      "type": "card",
      "variant": "elevated",
      "props": {
        "title": "\u2705 CLOSE",
        "content": "**Validation.** Readiness review, artifact emission, review freshness, documentation, handoff disposition.\n\nOperator question: *Is this proven and safely closed?*\n\nMaps to: review-readiness, validate-emit-learn, handoff"
      }
    },
