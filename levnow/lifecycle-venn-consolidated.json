{
  "meta": {
    "title": "Lifecycle Skill Taxonomy \u2014 7 Projects \u00d7 4 Lanes",
    "description": "Consolidated Venn: Shape/Plan/Deliver/Close across the 4 Os + Hermes + OpenClaw + Lev native",
    "layout": "sidebar-toc",
    "effects": [
      "card-glow",
      "title-underline",
      "grid-dots"
    ]
  },
  "theme": {
    "preset": "teal-slate",
    "mode": "dark"
  },
  "root": [
    "hero",
    "kpis",
    "lanes-overview",
    "venn-table",
    "shape-section",
    "plan-section",
    "deliver-section",
    "close-section",
    "unlaned-section",
