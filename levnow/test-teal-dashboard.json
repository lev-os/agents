{
  "meta": {
    "title": "Teal Dashboard Coverage Test",
    "description": "Tests pipeline section, full-width section, data-table, doughnut chart, KPI with sparkline/trend, grid-dots and card-glow effects",
    "effects": ["grid-dots", "card-glow"]
  },
  "theme": { "preset": "teal-slate", "mode": "dark" },
  "root": ["hero", "sec-kpis", "sec-pipeline", "sec-log", "sec-charts"],
  "elements": {
    "hero": {
      "type": "hero",
      "variant": "centered",
      "props": {
        "category": "DASHBOARD TEST",
        "title": "Teal System Dashboard",
        "subtitle": "Coverage matrix test: KPI sparklines, pipeline, full-width table, doughnut chart",
        "meta": "Last updated: 2026-04-06"
      }
    },

    "sec-kpis": {
      "type": "section",
      "variant": "kpi-row",
      "props": {
        "title": "System Health"
      },
      "children": ["kpi-uptime", "kpi-agents", "kpi-latency", "kpi-errors"]
    },
    "kpi-uptime": {
      "type": "card",
      "variant": "kpi",
      "props": {
        "value": "99.7",
        "label": "Uptime %",
        "trend": { "direction": "up", "value": "+0.2%" },
        "sparkline": [98, 99, 97, 99, 100, 99, 100]
      }
    },
    "kpi-agents": {
      "type": "card",
      "variant": "kpi",
      "props": {
        "value": "340",
        "label": "Active Agents",
        "trend": { "direction": "up", "value": "+12" }
      }
    },
    "kpi-latency": {
      "type": "card",
      "variant": "kpi",
      "props": {
        "value": "2.1",
        "label": "Avg Latency ms",
        "trend": { "direction": "down", "value": "-0.3" }
      }
    },
    "kpi-errors": {
      "type": "card",
      "variant": "kpi",
      "props": {
        "value": "18",
        "label": "Error Rate",
        "trend": { "direction": "flat", "value": "stable" }
      }
    },

    "sec-pipeline": {
      "type": "section",
      "variant": "pipeline",
      "props": {
        "title": "Deploy Pipeline"
      },
      "children": ["pipe-build", "pipe-stage", "pipe-canary", "pipe-rollout"]
    },
    "pipe-build": {
      "type": "card",
      "props": {
        "title": "Build",
        "content": "Compile & test",
        "tags": ["CI"]
      }
    },
    "pipe-stage": {
      "type": "card",
      "props": {
        "title": "Stage",
        "content": "Deploy to staging",
        "tags": ["CD"]
      }
    },
    "pipe-canary": {
      "type": "card",
      "props": {
        "title": "Canary",
        "content": "1% traffic",
        "tags": ["Prod"]
      }
    },
    "pipe-rollout": {
      "type": "card",
      "props": {
        "title": "Rollout",
        "content": "Full deploy",
        "tags": ["Prod"]
      }
    },

    "sec-log": {
      "type": "section",
      "variant": "full-width",
      "props": {
        "title": "Request Log"
      },
      "children": ["tbl-requests"]
    },
    "tbl-requests": {
      "type": "data-table",
      "props": {
        "columns": [
          { "key": "time", "label": "Time" },
          { "key": "method", "label": "Method" },
          { "key": "path", "label": "Path" },
          { "key": "status", "label": "Status" },
          { "key": "latency", "label": "Latency", "numeric": true },
          { "key": "agent", "label": "Agent" }
        ],
        "rows": [
          {
            "time": "21:15:03",
            "method": "POST",
            "path": "/api/exec",
            "status": { "status": "success", "text": "200" },
            "latency": "42ms",
            "agent": "opus-4"
          },
          {
            "time": "21:15:01",
            "method": "GET",
            "path": "/api/health",
            "status": { "status": "success", "text": "200" },
            "latency": "3ms",
            "agent": "system"
          },
          {
            "time": "21:14:58",
            "method": "POST",
            "path": "/api/render",
            "status": { "status": "success", "text": "200" },
            "latency": "1.8ms",
            "agent": "lev-now"
          },
          {
            "time": "21:14:55",
            "method": "POST",
            "path": "/api/exec",
            "status": { "status": "warning", "text": "429" },
            "latency": "0ms",
            "agent": "rate-limit"
          },
          {
            "time": "21:14:50",
            "method": "DELETE",
            "path": "/api/session/abc",
            "status": { "status": "error", "text": "500" },
            "latency": "150ms",
            "agent": "cleanup"
          }
        ]
      }
    },

    "sec-charts": {
      "type": "section",
      "props": {
        "title": "Charts"
      },
      "children": ["chart-doughnut"]
    },
    "chart-doughnut": {
      "type": "chart",
      "props": {
        "chartType": "doughnut",
        "title": "Request Distribution",
        "labels": ["exec", "render", "health", "session"],
        "datasets": [
          {
            "data": [45, 30, 20, 5],
            "backgroundColor": ["#0891b2", "#06b6d4", "#22d3ee", "#67e8f9"]
          }
        ]
      }
    }
  }
}