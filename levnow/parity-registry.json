{
  "meta": {
    "title": "Parity Registry | Structured Data",
    "description": "Comparison of structural data formats across Leviathan",
    "layout": "default",
    "effects": ["grid-lines", "title-underline"]
  },
  "theme": {
    "preset": "amber-emerald",
    "mode": "light"
  },
  "root": ["hero", "comparison_section"],
  "elements": {
    "hero": {
      "type": "hero",
      "variant": "centered",
      "props": {
        "category": "REGISTRY",
        "title": "Structured Data Parity",
        "subtitle": "Format comparison map: Everything + Upcoming"
      },
      "children": ["lead_text"]
    },
    "lead_text": {
      "type": "text",
      "variant": "lead",
      "props": {
        "content": "Lev relies on multiple structured data layers to transport information effectively. This registry tracks active formats, compression strategies like **Caveman**, and positional encodings mapping like **TOON** and **AXI**."
      }
    },
    "comparison_section": {
      "type": "section",
      "variant": "full-width",
      "props": {
        "label": "COMPARISON MATRIX",
        "title": "Format Landscape"
      },
      "children": ["parity_table"]
    },
    "parity_table": {
      "type": "data-table",
      "props": {
        "columns": [
          { "key": "format", "label": "Format Layer" },
          { "key": "status", "label": "Lifecycle Status" },
          { "key": "size", "label": "Compression / Size" },
          { "key": "usecase", "label": "Ideal Use Case" },
          { "key": "integration", "label": "Lev Integration Point" }
        ],
        "rows": [
          {
            "format": "JSON",
            "status": { "text": "Active", "status": "match" },
            "size": "Large (Uncompressed)",
            "usecase": "API payloads, schema drops",
            "integration": "Transport Layer"
          },
          {
            "format": "YAML",
            "status": { "text": "Active", "status": "match" },
            "size": "Medium",
            "usecase": "Config, templates, DNA",
            "integration": "Core / FlowMind Compilation"
          },
          {
            "format": "Beads (BD)",
            "status": { "text": "Active", "status": "match" },
            "size": "Tiny",
            "usecase": "Artifact state tracking",
            "integration": "Memory Checkpoints"
          },
          {
            "format": "LLMs.txt",
            "status": { "text": "Active", "status": "match" },
            "size": "Medium",
            "usecase": "Crawler context ingestion",
            "integration": "RAG Surface"
          },
          {
            "format": "AXI",
            "status": { "text": "Integrating", "status": "info" },
            "size": "Micro",
            "usecase": "Agent Tool Output & Terminal",
            "integration": "LevLoop CLI / Terminal"
          },
          {
            "format": "Caveman",
            "status": { "text": "Upcoming", "status": "warn" },
            "size": "Minimal (40-58% savings)",
            "usecase": "Agent CoT, Context Injection",
            "integration": "Agent Internal Processing"
          },
          {
            "format": "TOON",
            "status": { "text": "Upcoming", "status": "warn" },
            "size": "Compact (30-60% savings)",
            "usecase": "Uniform DB Arrays",
            "integration": "Query Result Transport"
          }
        ]
      }
    }
  }
}
