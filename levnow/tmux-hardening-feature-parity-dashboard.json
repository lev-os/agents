    "gate-code": {
      "type": "code-block",
      "props": {
        "language": "bash",
        "filename": "tmux-hardening-gates.sh",
        "showLineNumbers": true,
        "content": "ruby -e \"require 'yaml'; YAML.load_file('dna/core/tmux-harness.dna.yaml')\"\nrg -n \"~/(.codex|.claude|.pi)|OpenCode|jsonl|provider transcript|parse.*transcript\" core/tmux-harness/src && exit 1 || exit 0\nrg -n \"proof_state|healthy|green|certified|production_cert\" core/tmux-harness/src/execution-transport core/tmux-harness/src/execution-facade core/tmux-harness/src/evidence && exit 1 || exit 0\npnpm --dir core/tmux-harness test tests/harness/agent-session-execution-binding-smoke.test.ts tests/harness/agent-session-pane-delta.test.ts tests/harness/agent-session-timeout.test.ts\npnpm --dir core/tmux-harness test tests/pentagon/default-execution-transport.scenarios.test.ts\nbun core/harness/tests/boundary-audit.ts --mode=enforce --slice=S1_default_tmux_execution_transport"
      }
    },
