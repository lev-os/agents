    "module-shape": {
      "type": "section",
      "variant": "card-grid",
      "props": {
        "label": "Architecture",
        "title": "Target Internal Shape",
        "subtitle": "Modular monolith inside one tmux owner. AgentSession remains the public facade."
      },
      "children": [
        "module-contracts",
        "module-primitives",
        "module-session",
        "module-submission",
        "module-observation",
        "module-evidence",
        "module-exec",
        "module-registry",
        "module-warm",
        "module-eval"
      ]
    },
    "module-contracts": {
      "type": "card",
      "variant": "elevated",
      "props": {
        "title": "Contracts",
        "content": "Session URI, profile, substrate policy, and stable public types. No execution behavior or filesystem writes."
      }
    },
    "module-primitives": {
      "type": "card",
      "variant": "elevated",
      "props": {
        "title": "Tmux Primitives",
        "content": "Typed wrappers for spawn, attach, capture, input, and kill. Raw tmux commands stay here."
      }
    },
    "module-session": {
      "type": "card",
      "variant": "elevated",
      "props": {
        "title": "Session Facade",
        "content": "AgentSession compatibility constructor and methods. Delegates all real work to local modules."
      }
    },
    "module-submission": {
      "type": "card",
      "variant": "elevated",
      "props": {
        "title": "Submission",
        "content": "Submit-plan execution, dispatch request state, and dispatch events. No observation logic."
      }
    },
    "module-observation": {
      "type": "card",
      "variant": "elevated",
      "props": {
        "title": "Observation",
        "content": "Readiness, pane-delta, prompt echo stripping, wait patterns, and provider readiness blockers."
      }
    },
    "module-evidence": {
      "type": "card",
      "variant": "elevated",
      "props": {
        "title": "Evidence",
        "content": "Receipts, diagnostics replay, startup phase events. Byproducts only, never certification authority."
      }
    },
    "module-exec": {
      "type": "card",
      "variant": "elevated",
      "props": {
        "title": "Execution Facade",
        "content": "One-shot exec composition and artifact cleanup. Keeps ./execution-transport as compatibility export only."
      }
    },
    "module-registry": {
      "type": "card",
      "variant": "elevated",
      "props": {
        "title": "Registry + Reaper",
        "content": "Identity tags, XDG registry path/schema/store, stale cleanup, and ReaperOutcomeReceipt."
      }
    },
    "module-warm": {
      "type": "card",
      "variant": "elevated",
      "props": {
