    "tmux-diagram": {
      "type": "diagram",
      "props": {
        "engine": "mermaid",
        "caption": "Target dependency direction",
        "content": "flowchart LR\n  Exec[core/exec\\npublic execution lifecycle] --> Harness[core/harness\\nneutral router + binding]\n  Harness --> Facade[core/tmux-harness\\nexecution facade]\n  Facade --> AgentSession[AgentSession\\ncompatibility facade]\n  AgentSession --> Submission[submission]\n  AgentSession --> Observation[observation]\n  AgentSession --> Evidence[evidence]\n  AgentSession --> Primitives[tmux primitives]\n  Facade --> Registry[registry + reaper]\n  Warm[warm-worker lifecycle] --> Registry\n  Eval[tmux-owned eval scenarios] --> AgentSession\n  Platforms[plugins/platforms\\nprovider declarations] -. provider metadata .-> Harness\n  Platforms -. transcript locators only .-> Warm\n  classDef owner fill:#0f766e,color:#fff,stroke:#5eead4\n  classDef guard fill:#334155,color:#fff,stroke:#94a3b8\n  class Facade,AgentSession,Submission,Observation,Evidence,Primitives,Registry,Warm,Eval owner\n  class Exec,Harness,Platforms guard"
      }
    },
