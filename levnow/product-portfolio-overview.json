{
  "meta": {
    "title": "Leviathan x Kingly \u2014 Product Portfolio Overview",
    "description": "Meeting-ready overview of the Lev runtime, Graph-OS, kingly.cloud, AgentPing, ClawBuddy, ClawTok, Poly, and faba.gg.",
    "layout": "sidebar-toc",
    "effects": [
      "card-glow",
      "hero-gradient",
      "title-underline",
      "grid-dots"
    ]
  },
  "theme": {
    "preset": "deep-blue-gold",
    "mode": "dark"
  },
  "root": [
    "hero",
    "pulse-section",
    "hierarchy-section",
    "status-section",
    "domains-section",
    "presentation-section",
    "rules-section",
    "campaign-ux-section",
    "send-pack-section"
  ],
  "elements": {
    "hero": {
      "type": "hero",
      "variant": "centered",
      "props": {
        "category": "MEETING OVERVIEW",
        "title": "One runtime. Several surfaces. Clear roles.",
        "subtitle": "How Lev, Graph-OS, kingly.cloud, AgentPing, ClawBuddy, ClawTok, Poly, and faba.gg fit together without collapsing into one blurry brand.",
        "meta": "April 12, 2026 \u2014 meeting prep pack"
      },
      "children": [
        "hero-lead"
      ]
    },
    "hero-lead": {
      "type": "text",
      "variant": "lead",
      "props": {
        "content": "For mixed rooms, lead with outcomes and visible products. For infrastructure-native people, reveal the runtime story: **Lev** is the open agent runtime, **graph-os.ai** is the managed projection, **kingly.cloud** is the inference gateway, and **Poly** is the transport and manifest layer that lets the stack travel."
      }
    },
    "pulse-section": {
      "type": "section",
      "variant": "kpi-row",
      "props": {
        "label": "PULSE",
        "title": "Portfolio At A Glance"
      },
      "children": [
        "kpi-properties",
        "kpi-domains",
        "kpi-launches",
        "kpi-runtime",
        "kpi-decisions"
      ]
    },
    "kpi-properties": {
      "type": "card",
      "variant": "kpi",
      "props": {
        "value": 8,
        "label": "Named Properties",
        "trend": {
          "direction": "up",
          "value": "runtime + products + protocol"
        }
      }
    },
    "kpi-domains": {
      "type": "card",
      "variant": "kpi",
      "props": {
        "value": 5,
        "label": "Priority Domains",
        "trend": {
          "direction": "flat",
          "value": "graph-os.ai, kingly.cloud, lev.now, faba.gg, graph.store"
        }
      }
    },
    "kpi-launches": {
      "type": "card",
      "variant": "kpi",
      "props": {
        "value": 2,
        "label": "Immediate Launch Tracks",
        "trend": {
          "direction": "up",
          "value": "ClawTok Apr 13, AgentPing Apr 25"
        }
      }
    },
    "kpi-runtime": {
      "type": "card",
      "variant": "kpi",
      "props": {
        "value": 1,
        "label": "Core Runtime Story",
        "trend": {
          "direction": "flat",
          "value": "Lev = OSS, graph-os = managed projection"
        }
      }
    },
    "kpi-decisions": {
      "type": "card",
      "variant": "kpi",
      "props": {
        "value": 3,
        "label": "Meeting Decisions",
        "trend": {
          "direction": "warn",
          "value": "naming, domain roles, GTM order"
        }
      }
    },
    "hierarchy-section": {
      "type": "section",
      "variant": "default",
      "props": {
        "label": "STACK MAP",
        "title": "Product Hierarchy",
        "subtitle": "The runtime sits underneath the public surfaces. Products reveal the stack in stages depending on audience."
      },
      "children": [
        "hierarchy-diagram",
        "hierarchy-notes"
      ]
    },
    "hierarchy-diagram": {
      "type": "diagram",
      "props": {
        "content": "graph TD\n    Lev[\"Leviathan (Lev)\\nOSS agent runtime\"] --> GraphOS[\"graph-os.ai\\nmanaged projection\"]\n    Lev --> FlowMind[\"FlowMind\\ncontrol substrate\"]\n    Lev --> AgentPing[\"AgentPing\\nhuman-loop surfaces\"]\n    Lev --> AgentGuard[\"AgentGuard\\nscoped trust\"]\n    Lev --> Poly[\"Poly\\nARM + poly://\"]\n    GraphOS --> Kingly[\"kingly.cloud\\ninference gateway\"]\n    Kingly --> ClawBuddy[\"ClawBuddy\\nweb marketplace\"]\n    Kingly --> ClawTok[\"ClawTok\\nios app\"]\n    Faba[\"faba.gg\\necosystem hub\"] --> ClawBuddy\n    AgentPing --> ClawBuddy\n    GraphOS --> GraphStore[\"graph.store\\nfederated layer\"]\n    LevNow[\"lev.now\\npublic /now surface\"] --> GraphOS"
      }
    },
    "hierarchy-notes": {
      "type": "card",
      "variant": "elevated",
      "props": {
        "title": "How to talk about it",
        "content": "**Front-stage for mixed rooms:** Kingly x Leviathan, physical-world or creator outcomes, visible products, booked demos.\n\n**Reveal for technical buyers:** Lev is the open runtime, graph-os.ai is the managed cloud shape, kingly.cloud is the inference utility, and Poly is the protocol layer.\n\n**What not to do:** don't open with eight brand names or a taxonomy lecture. Let the architecture appear after someone asks what powers the demo."
      }
    },
    "status-section": {
      "type": "section",
      "variant": "full-width",
      "props": {
        "label": "STATUS MATRIX",
        "title": "What Each Property Does",
        "subtitle": "Role clarity is the fastest way to stop naming confusion in the room."
      },
      "children": [
        "status-table"
      ]
    },
    "status-table": {
      "type": "data-table",
      "props": {
        "columns": [
          {
            "key": "property",
            "label": "Property"
          },
          {
            "key": "role",
            "label": "Role",
            "wide": true
          },
          {
            "key": "audience",
            "label": "Audience"
          },
          {
            "key": "status",
            "label": "Status"
          },
          {
            "key": "domain",
            "label": "Domain"
          },
          {
            "key": "lead",
            "label": "Lead With",
            "wide": true
          }
        ],
        "rows": [
          {
            "property": "Lev",
            "role": "Open agent runtime and orchestration substrate",
            "audience": "builders / platform",
            "status": {
              "text": "Active",
              "status": "match"
            },
            "domain": "repo / docs",
            "lead": "runtime, constraints, receipts"
          },
          {
            "property": "graph-os.ai",
            "role": "Managed public projection of the graph-native operating model",
            "audience": "technical buyers / enterprise",
            "status": {
              "text": "Active",
              "status": "match"
            },
            "domain": "graph-os.ai",
            "lead": "/now projection + hygiene + deploy"
          },
          {
            "property": "kingly.cloud",
            "role": "Multi-provider inference gateway and billing layer",
            "audience": "developers / teams",
            "status": {
              "text": "Planning",
              "status": "warn"
            },
            "domain": "kingly.cloud",
            "lead": "single API, multimodal routing, credits"
          },
          {
            "property": "AgentPing",
            "role": "Human-loop surfaces, approvals, and interaction model",
            "audience": "operators / product teams",
            "status": {
              "text": "Sprint",
              "status": "warn"
            },
            "domain": "community/agentping",
            "lead": "surfaces, reviews, notifications"
          },
          {
            "property": "ClawBuddy",
            "role": "Web marketplace and consumer/product surface",
            "audience": "creators / buyers",
            "status": {
              "text": "Planning",
              "status": "info"
            },
            "domain": "future app/site",
            "lead": "marketplace, compare, trailers"
          },
          {
            "property": "ClawTok",
            "role": "Short-form iOS content app in the same ecosystem",
            "audience": "creators / consumers",
            "status": {
              "text": "Launching",
              "status": "warn"
            },
            "domain": "iOS app",
            "lead": "content surface, creator loop"
          },
          {
            "property": "Poly",
            "role": "ARM artifact + poly:// invocation scheme",
            "audience": "infra partners",
            "status": {
              "text": "Experimental",
              "status": "info"
            },
            "domain": "poly://",
            "lead": "manifest + protocol, not a consumer brand"
          },
          {
            "property": "faba.gg",
            "role": "Ecosystem hub and partner funnel",
            "audience": "partners / curious traffic",
            "status": {
              "text": "Planning",
              "status": "info"
            },
            "domain": "faba.gg",
            "lead": "ecosystem map, partner entry point"
          }
        ],
        "stickyHeader": true
      }
    },
    "domains-section": {
      "type": "section",
      "variant": "card-grid",
      "props": {
        "label": "DOMAIN ROLES",
        "title": "Which Domain Says What"
      },
      "children": [
        "domain-graphos",
        "domain-kingly",
        "domain-levnow",
        "domain-faba",
        "domain-graphstore"
      ]
    },
    "domain-graphos": {
      "type": "card",
      "variant": "elevated",
      "props": {
        "title": "graph-os.ai",
        "content": "The managed graph-native operating model. Use when the room wants the enterprise or platform shape of Lev."
      }
    },
    "domain-kingly": {
      "type": "card",
      "variant": "elevated",
      "props": {
        "title": "kingly.cloud",
        "content": "The inference utility layer. Use when the conversation turns to multimodal routing, credits, or embedded AI infrastructure."
      }
    },
    "domain-levnow": {
      "type": "card",
      "variant": "elevated",
      "props": {
        "title": "lev.now",
        "content": "The live public /now surface. Use for dashboards, manifestos, meeting pages, and sendable pages that show the stack working."
      }
    },
    "domain-faba": {
      "type": "card",
      "variant": "elevated",
      "props": {
        "title": "faba.gg",
        "content": "The ecosystem or partner hub. Use when you want one entrance into the broader product family without forcing the runtime story first."
      }
    },
    "domain-graphstore": {
      "type": "card",
      "variant": "elevated",
      "props": {
        "title": "graph.store",
        "content": "Reserved for the federated or marketplace layer. Mention as future-facing mesh and discovery substrate, not as today's opening pitch."
      }
    },
    "presentation-section": {
      "type": "section",
      "variant": "pipeline",
      "props": {
        "label": "ROOM FLOW",
        "title": "Recommended Presentation Order",
        "subtitle": "Reveal complexity in layers instead of dropping the whole ontology at once."
      },
      "children": [
        "step-outcomes",
        "step-products",
        "step-runtime",
        "step-protocol"
      ]
    },
    "step-outcomes": {
      "type": "card",
      "variant": "default",
      "props": {
        "title": "1. Outcomes",
        "content": "Start with the thing a mixed room can care about right away: demos, creator workflows, physical-world use cases, or booked product surfaces."
      }
    },
    "step-products": {
      "type": "card",
      "variant": "default",
      "props": {
        "title": "2. Product Surfaces",
        "content": "Show ClawTok, ClawBuddy, AgentPing, or the /now surfaces so people can attach the story to something visible."
      }
    },
    "step-runtime": {
      "type": "card",
      "variant": "default",
      "props": {
        "title": "3. Runtime Reveal",
        "content": "When someone asks what powers it, explain Lev as the runtime and graph-os.ai as the managed public projection."
      }
    },
    "step-protocol": {
      "type": "card",
      "variant": "default",
      "props": {
        "title": "4. Protocol Layer",
        "content": "Only go into Poly, ARM, and graph.store when the audience is clearly infra-native or partner-focused."
      }
    },
    "rules-section": {
      "type": "section",
      "variant": "comparison",
      "props": {
        "label": "MESSAGE DISCIPLINE",
        "title": "Say This / Avoid This"
      },
      "children": [
        "say-card",
        "avoid-card"
      ]
    },
    "say-card": {
      "type": "card",
      "variant": "callout",
      "props": {
        "variant": "success",
        "title": "Say this",
        "content": "Lead with outcomes. Frame Lev as a runtime, not a framework. Use graph-os.ai as the enterprise or managed projection. Treat kingly.cloud as the inference utility. Keep Poly as the protocol layer, not the headline for general audiences."
      }
    },
    "avoid-card": {
      "type": "card",
      "variant": "callout",
      "props": {
        "variant": "warning",
        "title": "Avoid this",
        "content": "Don't start with eight brands. Don't pitch every property as a top-level company. Don't force protocol language on mixed rooms. Don't let ClawTok and ClawBuddy sound unrelated if they share the same stack and gateway story."
      }
    },
    "campaign-ux-section": {
      "type": "section",
      "variant": "full-width",
      "props": {
        "label": "CAMPAIGN UX",
        "title": "Where This Story Lives In The Repo",
        "subtitle": "The campaign folders are now the browse surface. A human can start there without knowing the original authoring path."
      },
      "children": [
        "campaign-ux-table"
      ]
    },
