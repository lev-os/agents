    "sec-insight": {
      "type": "section",
      "variant": "default",
      "props": {
        "label": "INSIGHT",
        "title": "The FMM Reject Cascade"
      },
      "children": [
        "insight-text",
        "chart-failures"
      ]
    },
    "insight-text": {
      "type": "text",
      "variant": "prose",
      "props": {
        "content": "The dominant failure is a cascade: intent parser correctly identifies the instruction type but extracts wrong or incomplete parameters. FMM's fail-closed `_match_rule` correctly rejects because parameters don't match the scenario fixture rule. No FMM accept means no readback generated.\n\nThis is the **anti-cheat design working as intended**. Before session 30, the contractor's intent-only fallback would have accepted these \u2014 inflating the pass rate to 98%. The 49.4% is the honest number.\n\n**The fix is not in the harness.** It's in the pipeline: better parameter extraction, scenario rule alignment, and compound splitter coverage."
      }
    },
