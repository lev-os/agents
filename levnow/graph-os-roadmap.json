    "hero": {
      "type": "hero",
      "variant": "centered",
      "props": {
        "category": "STRATEGIC SYNTHESIS",
        "title": "graph-os Roadmap",
        "subtitle": "Competitive intelligence + infrastructure decisions + 4-phase execution plan",
        "meta": "April 12, 2026 — Synthesized from 3 deep research agents"
      },
      "children": ["hero-lead"]
    },
    "hero-lead": {
      "type": "text",
      "variant": "lead",
      "props": {
        "content": "Lev = everything. graph-os = Lev with a cloud config.yaml. Local-first capable, model-agnostic, constraint-enforced. The ONLY runtime where local and cloud are the same binary with a different config, and the ONLY one with a non-crypto federated mesh."
      }
    },
    "principle-section": {
      "type": "section",
      "variant": "default",
      "props": {
        "label": "DESIGN PRINCIPLE",
        "title": "config.yaml = Everything"
      },
      "children": ["principle-code"]
    },
    "principle-code": {
      "type": "code-block",
      "props": {
        "language": "yaml",
        "filename": "config.yaml",
        "content": "# Switch modes without changing code\nprovider:\n  inference: ollama          # local: free, offline\n  # inference: kingly.cloud  # cloud: multi-provider, pay-per-token\n  # inference: mesh          # federated: earn credits by serving\n  graph: sqlite              # local: zero deps\n  # graph: falkordb          # cloud: sub-ms latency\n  # graph: neo4j-aura        # enterprise: ecosystem\n  memory: local              # filesystem-backed\n  # memory: graphiti         # temporal knowledge graph\n  storage: filesystem        # local disk\n  # storage: supabase        # managed cloud"
      }
    },
