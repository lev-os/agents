      "type": "section",
      "variant": "default",
      "props": {
        "label": "TOPOLOGY",
        "title": "Meta-Substrate Layers"
      },
      "children": ["substrate-mermaid"]
    },
    "substrate-mermaid": {
      "type": "diagram",
      "props": {
        "content": "graph LR\n    D[\"config.yaml\\nDeclaration\"] --> C[\"lev install\\nCompiler\"]\n    C --> IR[\"Entity Graph\\nIR\"]\n    IR --> R1[\"Local Lev\\nRuntime\"]\n    IR --> R2[\"graph-os.ai\\nRuntime\"]\n    IR --> R3[\"ClawBuddy\\nRuntime\"]\n    IR --> R4[\"kingly.cloud\\nRuntime\"]\n    R1 --> F[\"graph.store\\nFederation\"]\n    R2 --> F\n    R3 --> F\n    R4 --> F"
      }
    },
