{
  "meta": {
    "title": "lev-now Variant Audit — every section + card variant",
    "layout": "sidebar-toc"
  },
  "theme": { "preset": "obsidian-monolith", "mode": "dark" },
  "root": [
    "hero",
    "v-default", "v-card-grid", "v-kpi-row",
    "v-comparison", "v-collapsible", "v-full-width",
    "v-stacked", "v-asymmetric",
    "card-variants", "callout-variants", "text-variants"
  ],
  "elements": {
    "hero": {
      "type": "hero",
      "variant": "editorial",
      "props": {
        "label": "VARIANT AUDIT",
        "title": "Every Variant",
        "subtitle": "Sweep of all section + card variants to detect padding, accent, and theme inconsistencies."
      }
    },
    "v-default": {
      "type": "section", "variant": "default",
      "props": { "label": "Section", "title": "default variant" },
      "children": ["card-default-1", "card-default-2"]
    },
    "v-card-grid": {
      "type": "section", "variant": "card-grid",
      "props": { "label": "Section", "title": "card-grid variant" },
      "children": ["card-default-3", "card-default-4", "card-default-5"]
    },
    "v-kpi-row": {
      "type": "section", "variant": "kpi-row",
      "props": { "label": "Section", "title": "kpi-row variant" },
      "children": ["kpi-1", "kpi-2", "kpi-3", "kpi-4"]
    },
    "v-comparison": {
      "type": "section", "variant": "comparison",
      "props": { "label": "Section", "title": "comparison variant" },
      "children": ["card-default-6", "card-default-7"]
    },
    "v-collapsible": {
      "type": "section", "variant": "collapsible",
      "props": { "label": "Section", "title": "collapsible variant" },
      "children": ["card-default-8"]
    },
    "v-full-width": {
      "type": "section", "variant": "full-width",
      "props": { "label": "Section", "title": "full-width variant" },
      "children": ["table-1"]
    },
    "v-stacked": {
      "type": "section", "variant": "stacked",
      "props": { "label": "Section", "title": "stacked variant" },
      "children": ["card-default-9", "card-default-10"]
    },
    "v-asymmetric": {
      "type": "section", "variant": "asymmetric",
      "props": { "label": "Section", "title": "asymmetric variant" },
      "children": ["card-default-11", "card-default-12"]
    },
    "card-variants": {
      "type": "section", "variant": "card-grid",
      "props": { "label": "Cards", "title": "Card variant matrix" },
      "children": ["card-default-13", "card-glass-1", "card-accent-left-1", "card-testimonial-1"]
    },
    "callout-variants": {
      "type": "section", "variant": "stacked",
      "props": { "label": "Cards", "title": "Callout variants (info / warning / success)" },
      "children": ["callout-info", "callout-warn", "callout-success"]
    },
    "text-variants": {
      "type": "section", "variant": "default",
      "props": { "label": "Text", "title": "Text variants" },
      "children": ["text-prose", "text-pullquote", "text-lead"]
    },
    "card-default-1": { "type": "card", "variant": "default", "props": { "title": "Default card 1", "content": "padding check — ALL sides should be even." } },
    "card-default-2": { "type": "card", "variant": "default", "props": { "title": "Default card 2", "content": "no left-border accent should appear." } },
    "card-default-3": { "type": "card", "variant": "default", "props": { "title": "Grid card 1", "content": "even padding." } },
    "card-default-4": { "type": "card", "variant": "default", "props": { "title": "Grid card 2", "content": "even padding." } },
    "card-default-5": { "type": "card", "variant": "default", "props": { "title": "Grid card 3", "content": "even padding." } },
    "card-default-6": { "type": "card", "variant": "default", "props": { "title": "Before", "content": "comparison left." } },
    "card-default-7": { "type": "card", "variant": "default", "props": { "title": "After", "content": "comparison right." } },
    "card-default-8": { "type": "card", "variant": "default", "props": { "title": "Collapsed content", "content": "open me." } },
    "card-default-9": { "type": "card", "variant": "default", "props": { "title": "Stack 1", "content": "stacked." } },
    "card-default-10": { "type": "card", "variant": "default", "props": { "title": "Stack 2", "content": "stacked." } },
    "card-default-11": { "type": "card", "variant": "default", "props": { "title": "Asym L", "content": "wider column." } },
    "card-default-12": { "type": "card", "variant": "default", "props": { "title": "Asym R", "content": "narrower column." } },
    "card-default-13": { "type": "card", "variant": "default", "props": { "title": "Default", "content": "Baseline card." } },
    "card-glass-1": { "type": "card", "variant": "glass", "props": { "title": "Glass", "content": "Glass variant — backdrop blur, no left accent." } },
    "card-accent-left-1": { "type": "card", "variant": "accent-left", "props": { "title": "Accent (was left, now top)", "content": "Was border-left — now border-top." } },
    "card-testimonial-1": { "type": "card", "variant": "testimonial", "props": { "quote": "No left-border accent here either.", "author": "QA" } },
    "kpi-1": { "type": "card", "variant": "kpi", "props": { "value": "100", "label": "metric one" } },
    "kpi-2": { "type": "card", "variant": "kpi", "props": { "value": "200", "label": "metric two" } },
    "kpi-3": { "type": "card", "variant": "kpi", "props": { "value": "300", "label": "metric three" } },
    "kpi-4": { "type": "card", "variant": "kpi", "props": { "value": "4 / 4", "label": "ratio metric" } },
    "callout-info": { "type": "card", "variant": "callout", "props": { "variant": "info", "title": "INFO callout", "content": "Background tint only — no left bar." } },
    "callout-warn": { "type": "card", "variant": "callout", "props": { "variant": "warning", "title": "WARNING callout", "content": "Background tint only — no left bar." } },
    "callout-success": { "type": "card", "variant": "callout", "props": { "variant": "success", "title": "SUCCESS callout", "content": "Background tint only — no left bar." } },
    "text-prose": { "type": "text", "variant": "prose", "props": { "content": "Standard prose paragraph for readability check. Lorem ipsum dolor sit amet, consectetur adipiscing elit." } },
    "text-pullquote": { "type": "text", "variant": "pullquote", "props": { "content": "A pullquote without a left-border accent — italic and surface-alt background only." } },
    "text-lead": { "type": "text", "variant": "lead", "props": { "content": "Lead paragraph with slightly larger size and accent first-line treatment." } },
    "table-1": {
      "type": "data-table",
      "props": {
        "columns": [
          { "key": "name", "label": "Variant" },
          { "key": "padding", "label": "Padding" },
          { "key": "accent", "label": "Accent" },
          { "key": "status", "label": "Status" }
        ],
        "rows": [
          { "name": "callout", "padding": "20×24px", "accent": "background tint only", "status": "✓ slop removed" },
          { "name": "pullquote", "padding": "24×28px", "accent": "background only", "status": "✓ slop removed" },
          { "name": "testimonial", "padding": "24px", "accent": "1px border", "status": "✓ slop removed" },
          { "name": "accent-left", "padding": "1.25rem", "accent": "border-top 2px", "status": "✓ converted" },
          { "name": "timeline-active", "padding": "default", "accent": "background tint", "status": "✓ slop removed" }
        ]
      }
    }
  }
}
