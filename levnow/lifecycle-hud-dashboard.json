          "title": "Collected for /interview",
          "columns": [
            {"key": "entity", "label": "Entity"},
            {"key": "question", "label": "Decision"},
            {"key": "options", "label": "Options"}
          ],
          "rows": [
            {"entity": "SDLC auto-dispatch", "question": "SessionStart hook vs /ll-only?", "options": "a) Hybrid (recommended) b) Hook-only c) /ll-only"},
            {"entity": "TOON adoption", "question": "Rust crate or JS port?", "options": "a) Rust (exists: toon-rs) b) JS port c) Both"}
          ]
        },
        {
          "type": "text",
          "content": "When all entities are paused → auto-trigger: flowmind://arch-interview-brief → /interview"
        }
      ]
    },
    {
