{
  "title": "HUD Template — Deep Blue Gold",
  "subtitle": "Always-on lifecycle status bar for /ll, /work, /sitrep",
  "theme": {"preset": "deep-blue-gold"},
  "layout": "sidebar-toc",
  "effects": ["grid-dots", "noise", "card-glow"],
  "sections": [
    {
      "type": "section",
      "title": "HUD Variants",
      "variant": "stacked",
      "children": [
        {
          "type": "card",
          "title": "Active Execution",
          "content": "🧬 lifecycle-engine ⚡3 📥0 ⏸️0 ✅29 | 🚦frame_complete=0.85 | ⏭️ scanner+cache+handoff | 🔁ll:t4 running"
        },
        {
          "type": "card",
          "title": "Idle / Parked",
          "content": "🧬 lifecycle-engine ⚡0 📥0 ⏸️2 ✅33 | 🚦convergence=0.94 | ⏭️ auto-dispatch step 3 | 🔁ll:parked 20min"
        },
        {
          "type": "card",
          "title": "All Paused — Decisions Needed",
          "content": "🧬 lifecycle-engine ⚡0 📥0 ⏸️5 ✅27 | 🚦PAUSED | ⏭️ flowmind://arch-interview → /interview | 🔁ll:parked"
        },
        {
          "type": "card",
          "title": "Session Complete",
          "content": "🧬 lifecycle-engine ⚡0 📥0 ⏸️0 ✅35 | 🚦DONE convergence=1.0 | ⏭️ /handoff | 🔁ll:stopped"
        }
      ]
    },
    {
      "type": "section",
      "title": "Symbol Key",
      "variant": "kpi-row",
      "children": [
        {"type": "card", "title": "🧬", "content": "Workstream ID"},
        {"type": "card", "title": "⚡", "content": "Executing Now"},
        {"type": "card", "title": "📥", "content": "Capturing"},
        {"type": "card", "title": "⏸️", "content": "Paused (decision)"},
        {"type": "card", "title": "✅", "content": "Done This Session"},
        {"type": "card", "title": "🚦", "content": "Gate = Score"},
        {"type": "card", "title": "⏭️", "content": "Next Action"},
        {"type": "card", "title": "🔁", "content": "Loop State"}
      ]
    },
    {
      "type": "section",
      "title": "When to Show",
      "variant": "default",
      "children": [
        {
          "type": "data-table",
          "title": "output_template: hud",
          "columns": [
            {"key": "skill", "label": "Skill"},
            {"key": "template", "label": "Output Template"},
            {"key": "when", "label": "Shows HUD When"}
          ],
          "rows": [
            {"skill": "/ll", "template": "hud", "when": "Every tick"},
            {"skill": "/work", "template": "hud", "when": "Every response"},
            {"skill": "/sitrep", "template": "hud", "when": "Always (+ expanded dashboard above)"},
            {"skill": "/exec", "template": "hud", "when": "After execution completes"},
            {"skill": "/capture", "template": "hud", "when": "After capture sweep"},
            {"skill": "/propose", "template": "hud", "when": "After proposal written"},
            {"skill": "/close", "template": "hud", "when": "After close sequence"},
            {"skill": "/interview", "template": "footer", "when": "Domain skill — uses footer instead"},
            {"skill": "/tribunal", "template": "footer", "when": "Domain skill — uses footer instead"},
            {"skill": "/now", "template": "footer", "when": "Domain skill — uses footer instead"}
          ]
        }
      ]
    }
  ]
}
