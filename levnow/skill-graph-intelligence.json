      "variant": "editorial",
      "props": {
        "category": "GRAPH INTELLIGENCE \u00b7 v1.0",
        "title": "The Graph Analyzes Itself",
        "subtitle": "25 spikes \u00b7 6 sidecars \u00b7 155 nodes \u00b7 3 independent validations \u00b7 95.10% cluster agreement \u00b7 \u03c7=4",
