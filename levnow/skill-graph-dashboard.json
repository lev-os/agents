{
  "meta": {
    "title": "Skill Graph Dashboard",
    "description": "Real-time visualization of skill graph metrics, centrality analysis, and pipeline lanes",
    "refresh": 60,
    "effects": [
      "grid-dots",
      "card-glow"
    ]
  },
  "theme": {
    "preset": "deep-blue-gold",
    "mode": "dark"
  },
  "root": [
    "hero",
    "kpi-section",
    "cards-section",
    "pipeline-section"
  ],
  "elements": {
    "hero": {
      "type": "hero",
      "variant": "centered",
      "props": {
        "title": "Skill Graph Intelligence",
        "subtitle": "Network analysis dashboard with centrality metrics and lane pipeline",
        "category": "Analytics"
      }
    },
    "kpi-section": {
      "type": "section",
      "variant": "kpi-row",
      "props": {
        "title": "Key Metrics"
      },
      "children": [
        "kpi-nodes",
        "kpi-edges",
        "kpi-skills",
        "kpi-lanes"
      ]
    },
    "kpi-nodes": {
      "type": "card",
      "variant": "kpi",
      "props": {
        "label": "Total Nodes",
        "value": 155,
        "animate": true
      }
    },
    "kpi-edges": {
      "type": "card",
      "variant": "kpi",
      "props": {
        "label": "Total Edges",
        "value": 112,
        "animate": true
      }
    },
    "kpi-skills": {
      "type": "card",
      "variant": "kpi",
      "props": {
        "label": "Skills",
        "value": 46,
        "animate": true
      }
    },
    "kpi-lanes": {
      "type": "card",
      "variant": "kpi",
      "props": {
        "label": "Lanes",
        "value": 4,
        "animate": true
      }
    },
