      "variant": "comparison",
      "children": [
        {
          "type": "data-table",
          "headers": ["Field", "Fast Path", "Final Boss", "Parity"],
          "rows": [
            ["turn_id", "from TurnSpec", "from daemon", "27/27"],
            ["passed / intent_correct / params_correct", "derived", "derived", "exact match"],
            ["expected_intent / observed_intent", "from cascade", "from daemon cascade", "exact match"],
            ["expected_parameters / observed_parameters", "from cascade", "from daemon cascade", "exact match"],
            ["expected_fmm / observed_fmm", "from FMM rules", "from FMM daemon", "exact match"],
            ["readback_text / readback_ok", "from resolver", "from response daemon", "exact match"],
            ["first_broken_stage", "derived", "derived", "exact match"],
            ["failure_domain / failed_gate", "from _FAILURE_DOMAIN_MAP", "from enricher", "exact match"],
            ["splitter_telemetry", "real (DeBERTa splitter)", "real (daemon compound)", "populated"],
            ["reducer_telemetry", "simplified (best-segment)", "full (daemon reducer)", "partial"],
            ["cascade_ab", "from CascadeResult.provenance", "from daemon cascade", "populated"],
            ["timeline", "wall-clock (in-process)", "wall-clock (cross-daemon)", "populated (different scope)"],
            ["spec_refs / remediation / stage", "from lookup table", "from enricher", "exact match"]
          ]
        }
      ]
